rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products — anyone can read, anyone can write (admin via dashboard)
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders — user can read/write only their own orders; admin reads all
    match /orders/{orderId} {
      // Any logged-in write (placing an order) — keep open for custom auth
      allow write: if true;
      // Users can read their own orders (matched by userId field)
      // Admin reads all (public for now; restrict further once Firebase Auth is used)
      allow read: if true;
    }

    // Users collection (custom auth — signup/login data)
    match /users/{userId} {
      allow read, write: if true;
    }

    // User carts / wishlists (future)
    match /user_carts/{userId} {
      allow read, write: if true;
    }

    // Offer Banners — public read, admin write
    match /offerBanners/{bannerId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
